// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model CodeSnapshot {
  id        String   @id @default(cuid())
  roomId    String
  version   Int
  code      String
  createdAt DateTime @default(now())
}
